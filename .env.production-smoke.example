# Copy to .env.production-smoke before running:
# docker compose -f deploy/docker-compose.production-smoke.yml up -d --build

DB_NAME=bias_smoke
DB_USER=bias_smoke
DB_PASSWORD=bias-smoke-local-password-not-for-production

SECRET_KEY=bias-smoke-local-django-secret-key-not-for-production-64-bytes
JWT_SECRET_KEY=bias-smoke-local-jwt-secret-key-not-for-production-64-bytes

SITE_DOMAINS=localhost
SITE_SCHEME=http
FRONTEND_URL=http://localhost:8000
WEB_PORT=8000
WEB_CONCURRENCY=2
DB_CONN_MAX_AGE=0
DB_CONN_HEALTH_CHECKS=1

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=smoke-user
EMAIL_HOST_PASSWORD=smoke-password
DEFAULT_FROM_EMAIL=noreply@example.com

CELERY_CONCURRENCY=2
CELERY_MAX_TASKS_PER_CHILD=200

CSRF_COOKIE_SECURE=0
SESSION_COOKIE_SECURE=0
DEBUG=0
