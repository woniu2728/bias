[run]
source = apps,config,extensions
omit =
    */migrations/*
    */tests/*
    */test_*.py
    */__pycache__/*
    .venv/*
    venv/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    def __str__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if settings.DEBUG:
    class .*\bProtocol\b\)?:
    @(abc\.)?abstractmethod

fail_under = 70
show_missing = True
skip_covered = False

[html]
directory = htmlcov
