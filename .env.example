# Docker 基础设施变量
#
# 使用 Docker 安装前，请先复制为 .env 并填写。
# 这些变量没有安全默认值，缺失时 docker compose 会直接报错。

DB_NAME=replace-with-db-name
DB_USER=replace-with-db-user
DB_PASSWORD=replace-with-strong-password
DB_PORT=5432

# 首次安装可留空，install_forum 会写入随机强密钥到 instance/site.json。
# 已安装站点请不要随意修改 instance/site.json 中的密钥。
SECRET_KEY=
JWT_SECRET_KEY=

# 本地 http 演示可保留默认；正式 https 部署请改为 https 并开启 secure cookie。
FRONTEND_URL=http://localhost:8080
SITE_SCHEME=http
CSRF_COOKIE_SECURE=0
SESSION_COOKIE_SECURE=0

# Redis 可选密码；设置后 web/celery 会自动使用带密码的连接串。
REDIS_PASSWORD=

# Celery 默认并发，避免按宿主机 CPU 数启动过多 worker。
WEB_CONCURRENCY=2
CELERY_CONCURRENCY=2
CELERY_MAX_TASKS_PER_CHILD=200

# 邮件配置。生产环境建议改为 SMTP 后端，避免安装后生产自检被 console 邮件后端阻断。
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com

# 本地开发调试可选开关，生产保持 0。
DEBUG_TOOLBAR=0
