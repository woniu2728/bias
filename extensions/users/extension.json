{
  "id": "users",
  "name": "Users",
  "version": "0.1.0",
  "description": "提供用户资料、用户组、权限分配与封禁管理能力。",
  "icon": "fas fa-users",
  "category": "feature",
  "authors": [
    "Bias"
  ],
  "dependencies": [
    "core",
    "realtime"
  ],
  "provides": [
    "profiles",
    "groups",
    "suspension"
  ],
  "django_app_config": "extensions.users.backend.apps.UsersExtensionConfig",
  "django_app_label": "users",
  "backend_entry": "extensions.users.backend.ext",
  "frontend_admin_entry": "extensions/users/frontend/admin/index.js",
  "security": {
    "support_email": "",
    "capabilities_notice": "该扩展承载用户资料、用户组和封禁管理入口；Django AppConfig 与 Django 迁移模块均由扩展目录统一声明。"
  },
  "extra": {
    "auto_install": true,
    "auto_enable": true,
    "protected": true,
    "protected_reason": "该扩展承载用户、权限和认证基础域，不能在后台停用或卸载。"
  }
}
