{
  "id": "users",
  "name": "Users",
  "version": "0.1.0",
  "description": "提供用户资料、用户组、权限分配与封禁管理能力。",
  "icon": "fas fa-users",
  "category": "feature",
  "authors": [
    "Bias"
  ],
  "dependencies": [
    "core"
  ],
  "provides": [
    "profiles",
    "groups",
    "suspension"
  ],
  "django_app_config": "extensions.users.backend.apps.UsersExtensionConfig",
  "django_app_label": "users",
  "django_migration_module": "apps.users.migrations",
  "backend_entry": "extensions.users.backend.ext",
  "frontend_admin_entry": "extensions/users/frontend/admin/index.js",
  "compatibility": {
    "bias_version": "^1.0.0",
    "api_version": "1.0",
    "api_stability": "experimental",
    "api_stability_label": "实验性",
    "breaking_change_policy": "扩展协议调整会随 Bias 主版本升级同步说明。"
  },
  "security": {
    "support_email": "",
    "capabilities_notice": "该扩展承载用户资料、用户组和封禁管理入口；Django AppConfig 由扩展声明，迁移模块复用历史路径以保持数据库连续性。"
  },
  "distribution": {
    "channel": "private",
    "channel_label": "私有分发"
  },
  "extra": {
    "auto_install": true,
    "auto_enable": true,
    "protected": true,
    "protected_reason": "该扩展承载用户、权限和认证基础域，不能在后台停用或卸载。"
  }
}
