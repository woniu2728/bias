  "description": "提供 Composer 附件上传和上传策略接口。",
  "icon": "fas fa-paperclip",
  "category": "feature",
  "authors": [
    "Bias"
  ],
  "dependencies": [
    "core"
  ],
  "provides": [
    "composer-uploads",
    "upload-policy"
  ],
  "backend_entry": "extensions.uploads.backend.ext",
  "frontend_admin_entry": "extensions/uploads/frontend/admin/index.js",
  "frontend_forum_entry": "extensions/uploads/frontend/forum/index.js",
  "compatibility": {
    "bias_version": "^1.0.0",
    "api_version": "1.0",
    "api_stability": "experimental",
