{
  "id": "posts",
  "name": "Posts",
  "version": "0.1.0",
  "description": "提供帖子流、回复实体、帖子类型与楼层内容输出能力。",
  "icon": "far fa-comment",
  "category": "feature",
  "authors": [
    "Bias"
  ],
  "dependencies": [
    "core",
    "users"
  ],
  "provides": [
    "post-stream",
    "post-detail",
    "post-types"
  ],
  "django_app_config": "extensions.posts.backend.apps.PostsExtensionConfig",
  "django_app_label": "posts",
  "django_migration_module": "apps.posts.migrations",
  "migration_namespace": "extensions.posts.backend.migrations",
  "backend_entry": "extensions.posts.backend.ext",
  "compatibility": {
    "bias_version": "^1.0.0",
    "api_version": "1.0",
    "api_stability": "experimental",
    "api_stability_label": "实验性",
    "breaking_change_policy": "扩展协议调整会随 Bias 主版本升级同步说明。"
  },
  "security": {
    "support_email": "",
    "capabilities_notice": "该扩展承载帖子类型注册和帖子流基础能力；Django AppConfig 由扩展声明，迁移模块复用历史路径以保持数据库连续性。"
  },
  "distribution": {
    "channel": "private",
    "channel_label": "私有分发"
  },
  "extra": {
    "auto_install": true,
    "auto_enable": true,
    "protected": true,
    "protected_reason": "该扩展承载帖子流和回复基础域，不能在后台停用或卸载。"
  }
}
