{
  "id": "search",
  "name": "Search",
  "version": "0.1.0",
  "description": "提供论坛搜索过滤语法和搜索能力扩展点。",
  "icon": "fas fa-search",
  "category": "feature",
  "authors": [
    "Bias"
  ],
  "dependencies": [
    "core",
    "discussions",
    "emoji",
    "posts",
    "realtime",
    "users"
  ],
  "provides": [
    "search-filters",
    "search-filter-syntax"
  ],
  "backend_entry": "extensions.search.backend.ext",
  "frontend_forum_entry": "extensions/search/frontend/forum/index.js",
  "compatibility": {
    "bias_version": "^1.0.0",
