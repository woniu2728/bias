{
  "id": "tags",
  "name": "Tags",
  "version": "0.1.0",
  "description": "提供讨论标签、层级标签、标签可见性、标签权限和标签筛选能力。",
  "icon": "fas fa-tags",
  "category": "feature",
  "authors": [
    "Bias"
  ],
  "dependencies": [
    "core",
    "discussions",
    "posts",
    "realtime",
    "users"
  ],
  "optional_dependencies": [
    "flags"
  ],
  "provides": [
    "tagging",
    "tag-permissions",
    "tag-hierarchy",
    "tag-stats-refresh"
  ],
  "backend_entry": "extensions.tags.backend.ext",
  "django_app_config": "extensions.tags.backend.apps.TagsExtensionConfig",
  "django_app_label": "tags",
  "security": {
    "support_email": "",
    "capabilities_notice": "该扩展影响讨论标签展示、标签筛选、标签访问范围和标签管理接口。"
  },
  "extra": {
    "auto_install": true,
    "auto_enable": true
  }
