{
  "id": "emoji",
  "name": "Emoji",
  "version": "0.1.0",
  "description": "为编辑器提供表情按钮、:emoji 自动补全，并对帖子与通知内容进行 Twemoji 渲染。",
  "icon": "far fa-face-smile",
  "category": "feature",
  "authors": [
    "Bias"
  ],
  "documentation_url": "",
  "dependencies": [
    "core"
  ],
  "provides": [
    "emoji-composer",
    "emoji-renderer"
  ],
  "backend_entry": "extensions.emoji.backend.ext",
  "security": {
    "support_email": "",
    "capabilities_notice": "该扩展仅接管前台表情输入与渲染，不会额外申请高权限。"
  },
  "extra": {
    "auto_install": true,
    "auto_enable": true
  }
}
