{
  "id": "realtime",
  "name": "Realtime",
  "version": "0.1.0",
  "description": "提供 WebSocket 连接、通知实时推送和论坛实时信号能力。",
  "icon": "fas fa-bolt",
  "category": "infrastructure",
  "authors": [
    "Bias"
  ],
  "dependencies": [
    "core",
    "notifications"
  ],
  "provides": [
    "websocket",
    "presence",
    "typing"
  ],
  "backend_entry": "extensions.realtime.backend.ext",
  "compatibility": {
    "bias_version": "^1.0.0",
    "api_version": "1.0",
    "api_stability": "experimental",
    "api_stability_label": "实验性",
    "breaking_change_policy": "扩展协议调整会随 Bias 主版本升级同步说明。"
  },
  "security": {
    "support_email": "",
    "capabilities_notice": "该扩展负责实时连接与实时通知投递。"
  },
  "distribution": {
    "channel": "private",
    "channel_label": "私有分发"
  },
  "extra": {
    "auto_install": true,
    "auto_enable": true
  }
}
