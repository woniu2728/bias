{
  "id": "sample-hello",
  "name": "Sample Hello",
  "version": "0.1.0",
  "description": "用于验证 Bias 扩展发现、清单展示和后续扩展协议的示例扩展。",
  "icon": "fas fa-plug",
  "category": "feature",
  "authors": [
    "Bias"
  ],
  "documentation_url": "/admin.html#/admin/docs?guide=extension-system-roadmap&extension=sample-hello",
  "dependencies": [
    "core"
  ],
  "provides": [
    "sample-hello-panel"
  ],
  "backend_entry": "extensions.sample_hello.backend.ext",
  "frontend_admin_entry": "extensions/sample-hello/frontend/admin/index.js",
  "settings_pages": [
    "/admin/extensions/sample-hello/settings"
  ],
  "permissions_pages": [
    "/admin/extensions/sample-hello/permissions"
  ],
  "operations_pages": [
    "/admin/extensions/sample-hello/operations"
  ],
  "compatibility": {
    "bias_version": "^1.0.0",
    "api_version": "1.0",
    "api_stability": "experimental",
    "api_stability_label": "实验性",
    "breaking_change_policy": "Bias 在主版本升级前会通过路线图和开发文档提前说明扩展协议 breaking change。"
  },
  "security": {
    "support_email": "security@bias.local",
    "capabilities_notice": "示例扩展仅用于本地协议验证，不建议直接作为生产能力安装。"
  },
  "distribution": {
    "channel": "private",
    "channel_label": "私有分发",
    "signing_key_id": "",
    "signature_url": ""
  },
  "migration_namespace": "extensions.sample_hello.backend.migrations",
  "admin_actions": [
    {
      "key": "details",
      "label": "查看详情",
      "kind": "route",
      "target": "/admin/extensions/sample-hello",
      "icon": "fas fa-arrow-right",
      "tone": "primary",
      "order": 10
    },
    {
      "key": "settings",
      "label": "设置",
      "kind": "route",
      "target": "/admin/extensions/sample-hello/settings",
      "icon": "fas fa-sliders-h",
      "tone": "default",
      "requires_enabled": true,
      "order": 20
    },
    {
      "key": "permissions",
      "label": "权限",
      "kind": "route",
      "target": "/admin/extensions/sample-hello/permissions",
      "icon": "fas fa-user-shield",
      "tone": "default",
      "requires_enabled": true,
      "order": 30
    },
    {
      "key": "operations",
      "label": "操作",
      "kind": "route",
      "target": "/admin/extensions/sample-hello/operations",
      "icon": "fas fa-screwdriver-wrench",
      "tone": "default",
      "requires_enabled": true,
      "order": 40
    },
    {
      "key": "documentation",
      "label": "文档",
      "kind": "link",
      "target": "/admin.html#/admin/docs?guide=extension-system-roadmap&extension=sample-hello",
      "icon": "fas fa-book",
      "tone": "subtle",
      "order": 50
    }
  ],
  "extra": {
    "display_order": 1000,
    "experimental": true
  }
}
